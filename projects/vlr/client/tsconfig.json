{
    "compilerOptions": {
        "lib": ["es6", "dom", "es2017"],
        "module": "commonjs",
		"target": "ES2020",
		"esModuleInterop": true,
		"sourceMap": true,
		"strict": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"alwaysStrict": true,
		"noUnusedLocals": true,
    	"noUnusedParameters": true,
    	"pretty": true,
        "jsx": "react-jsx",
		"typeRoots": [
			"node_modules/@types"
		]
	},
	"exclude": [
		"node_modules"
	]
}
