{
  "name": "manage-machines",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "link-mm": "sudo ln -s $(pwd)/mm /usr/local/bin/mm",
    "copy-files": "copyfiles \"src/**/*.{jpg,jpeg,png,bmp,gif,conf}\" dist",
    "build": "rm -rf ./dist && rm -f ./tsconfig.tsbuildinfo && tsc && npm run copy-files",
    "build:watch": "rm -rf ./dist && rm -f ./tsconfig.tsbuildinfo && tsc --watch",
    "require:bun": "command -v bun >/dev/null 2>&1 || { echo 'Error: bun is not installed. See https://bun.sh/docs/installation'; exit 1; }",
    "bundle": "npm run require:bun && rm -rf ./build && bun build src/index.ts --compile --outfile build/mm-bin",
    "typecheck": "tsc --noEmit",
    "completion": "tsx src/argv.ts completion"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@sinclair/typebox": "0.34.48",
    "chalk": "5.6.2",
    "strip-ansi": "7.1.2",
    "typebox": "1.1.3",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@types/node": "25.3.0",
    "@types/source-map-support": "0.5.10",
    "@types/yargs": "17.0.35",
    "chokidar": "5.0.0",
    "copyfiles": "2.4.1",
    "eslint": "10.0.2",
    "eslint-plugin-import": "2.32.0",
    "source-map-support": "0.5.21",
    "tsx": "4.21.0",
    "type-fest": "5.4.4",
    "typescript": "5.9.3"
  }
}
